# ==========================================================================
# GitCade — environment template
# --------------------------------------------------------------------------
# Copy to .env and fill the BLANKS. Values already filled below are the local
# dev defaults that match the running ~/gitcade-infra Docker stack (Postgres +
# MinIO) — leave them as-is for local work. Blank keys are external accounts
# you must create once (see PHASE0-CHECKLIST.md for how to get each).
#
# .env is gitignored. NEVER commit real secrets. NEVER invent values for
# external services — a missing external key is a [CRITICAL] halt per
# ENVIRONMENT.md, not a thing to guess.
# ==========================================================================

# --- Database (LOCAL: already running, no action needed) ------------------
# Postgres 16 from ~/gitcade-infra. Doubles as the build job queue (the queue
# is a Postgres table — there is NO external queue service). Swap to a managed
# Postgres URL (Neon/Supabase/RDS) only at deploy time.
DATABASE_URL=postgresql://gitcade:gitcade@localhost:5432/gitcade

# --- GitHub: org + OAuth App (REQUIRED — create these) --------------------
# GITHUB_ORG: the org that holds seed games + user forks (e.g. gitcade-games).
GITHUB_ORG=
# OAuth App (platform login + repo ops under the user's token). Scopes the app
# requests: read:user user:email public_repo  (public_repo is REQUIRED — forks
# and remix commits 403 without it).
GITHUB_OAUTH_ID=
GITHUB_OAUTH_SECRET=

# --- GitHub App: governance auto-commits + app-level webhook (REQUIRED) ----
# A GitHub App (NOT the OAuth App) registered under the org. Used for passed-
# proposal auto-commits via per-repo installations and for the single app-level
# push webhook covering every installed repo. Installation IDs are per-Game
# DATABASE rows captured at publish time — they are NOT env vars.
GITHUB_APP_ID=
# The App's private key (PEM). Either paste the whole PEM as one line with
# literal \n between lines, OR set GITHUB_APP_PRIVATE_KEY_PATH instead and leave
# this blank. Do not commit the .pem file.
GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_PRIVATE_KEY_PATH=./secrets/gitcade-app.private-key.pem
# Webhook secret you set when registering the App's webhook.
GITHUB_WEBHOOK_SECRET=
# smee.io channel URL (local webhook proxy — GitHub can't reach localhost).
# Set this same URL as the App's webhook URL. Swap to the real endpoint at deploy.
WEBHOOK_PROXY_URL=

# --- Object storage (LOCAL: already running, no action needed) ------------
# MinIO from ~/gitcade-infra. The SAME client must work for MinIO and real
# S3/R2 via these env vars. S3_FORCE_PATH_STYLE=true is REQUIRED for MinIO;
# set false for real S3 (hardcoding either breaks the other).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=gitcade-artifacts
S3_ACCESS_KEY_ID=gitcade
S3_SECRET_ACCESS_KEY=gitcade-secret
S3_FORCE_PATH_STYLE=true

# --- Artifact serving (LOCAL defaults) ------------------------------------
# The dedicated artifact server (built in 4A) streams built games with the
# strict game CSP. Port 3001 is RESERVED for it. ARTIFACT_BASE_URL is the
# origin the iframe loads from — a SEPARATE domain in prod (security isolation).
ARTIFACT_SERVER_PORT=3001
ARTIFACT_BASE_URL=http://localhost:3001

# --- Build worker (LOCAL defaults) ----------------------------------------
# Builder image name (its Dockerfile is defined in Phase 4A: Node 22 + Chromium
# + build deps). The worker launches sibling containers from this image.
BUILDER_IMAGE=gitcade-builder:local
# How often the worker polls the Postgres queue table for new jobs.
QUEUE_POLL_INTERVAL_MS=2000

# --- NextAuth (platform auth) ---------------------------------------------
# NEXTAUTH_URL: the app's own base URL. NEXTAUTH_SECRET: generate with
#   openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- Tooling (not consumed by the app; for build sessions) ----------------
# Anthropic API key for running the Claude Code build sessions. Optional here
# if Claude Code is already authenticated another way.
# ANTHROPIC_API_KEY=
