    {
      "id": "paddle",
      "sprite": {
        "kind": "shape",
        "shape": "rect",
        "color": "#f4f4f4"
      },
      "size": {
        "w": 110,
        "h": 16
      },
      "position": {
        "x": 345,
        "y": 560
      },
      "tags": [
        "paddle"
      ],
      "layer": 3,
      "behaviors": [
        {
          "type": "move-4dir",
          "part": "move-4dir@1.0.0",
          "params": {
            "speed": "$cfg.paddleSpeed",
            "up": [
              "NoUp"
            ],
            "down": [
              "NoDown"
            ],
            "left": [
              "ArrowLeft",
              "KeyA"
            ],
            "right": [
              "ArrowRight",
              "KeyD"
            ]
          }
        },
        {
          "type": "velocity",
          "params": {}
        },
        {
          "type": "clamp-to-world",
          "params": {
            "axis": "x",
            "padding": 8
          }
        }
      ]
    },
    {
      "id": "ball",
      "sprite": {
        "kind": "shape",
        "shape": "circle",
        "color": "#ffcd75"
      },
      "size": {
        "w": 14,
        "h": 14
      },
      "position": {
        "x": 393,
        "y": 400
      },
      "tags": [
        "ball"
      ],
      "layer": 4,
      "behaviors": [
        {
          "type": "bounce-world-edges",
          "params": {
            "edges": [
              "top",
              "left",
              "right"
            ],
            "restitution": "$cfg.wallRestitution"
          }
        },
        {
          "type": "reflect-on-hit",
          "params": {
            "tag": "paddle",
            "axis": "y",
            "english": "$cfg.paddleEnglish",
            "speedScale": "$cfg.paddleSpeedup",
            "maxSpeed": "$cfg.ballMaxSpeed"
          }
        },
        {
          "type": "reflect-on-hit",
          "params": {
            "tag": "breakable",
            "axis": "auto"
          }
        },
        {
          "type": "contact-damage",
          "part": "contact-damage@1.0.0",
          "params": {
            "targetTag": "breakable",
            "damage": "$cfg.ballDamage",
            "cooldown": "$cfg.ballHitCooldown"
          }
        },
        {
          "type": "velocity",
          "params": {
            "vx": "$cfg.ballSpeedX",
            "vy": "$cfg.ballSpeedY"
          }
        }
      ]
    },
