{
  "id": "play-base",
  "size": { "width": 800, "height": 600 },
  "background": { "color": "#0b0b16", "layers": [{ "src": "assets/backgrounds/starfield.png", "scrollX": 0, "scrollY": 0 }] },
  "entities": [
    {
      "id": "paddle",
      "sprite": { "kind": "shape", "shape": "rect", "color": "#f4f4f4" },
      "size": { "w": 110, "h": 16 },
      "position": { "x": 345, "y": 560 },
      "tags": ["paddle"],
      "layer": 3,
      "behaviors": [
        { "type": "keyboard-axis", "params": { "axis": "x", "neg": ["ArrowLeft", "KeyA"], "pos": ["ArrowRight", "KeyD"], "speed": "$cfg.paddleSpeed", "touch": true } },
        { "type": "velocity", "params": {} },
        { "type": "clamp-to-world", "params": { "axis": "x", "padding": 8 } }
      ]
    },
    {
      "id": "ball",
      "sprite": { "kind": "shape", "shape": "circle", "color": "#ffcd75" },
      "size": { "w": 14, "h": 14 },
      "position": { "x": 393, "y": 400 },
      "tags": ["ball"],
      "layer": 4,
      "behaviors": [
        { "type": "bounce-world-edges", "params": { "edges": ["top", "left", "right"], "restitution": "$cfg.wallRestitution" } },
        { "type": "reflect-on-hit", "params": { "tag": "paddle", "axis": "y", "english": "$cfg.paddleEnglish", "speedScale": "$cfg.paddleSpeedup", "maxSpeed": "$cfg.ballMaxSpeed" } },
        { "type": "reflect-on-hit", "params": { "tag": "breakable", "axis": "auto" } },
        { "type": "contact-damage", "part": "contact-damage@1.0.0", "params": { "targetTag": "breakable", "damage": "$cfg.ballDamage", "cooldown": "$cfg.ballHitCooldown" } },
        { "type": "velocity", "params": { "vx": "$cfg.ballSpeedX", "vy": "$cfg.ballSpeedY" } },
        { "type": "scale-by-state", "part": "scale-by-state@1.0.0", "params": { "target": "velocity", "mode": "once", "levelKey": "level", "perLevel": "$cfg.ballSpeedPerLevel" } }
      ]
    },
    {
      "id": "killzone",
      "sprite": { "kind": "none" },
      "size": { "w": 800, "h": 10 },
      "position": { "x": 0, "y": 598 },
      "tags": ["killzone"],
      "layer": 0,
      "behaviors": [
        { "type": "trigger-zone", "part": "trigger-zone@1.0.0", "params": { "tag": "ball", "kill": true, "enterEvent": "ball-lost", "sound": "lose" } }
      ]
    },
    {
      "id": "hud-score",
      "sprite": { "kind": "text", "bind": "score", "text": "0", "font": "20px monospace", "color": "#f4f4f4", "align": "left" },
      "size": { "w": 160, "h": 24 },
      "position": { "x": 60, "y": 10 },
      "tags": ["hud"],
      "layer": 100
    },
    {
      "id": "hud-level",
      "sprite": { "kind": "text", "bind": "levelDisplay", "text": "LEVEL 1", "font": "20px monospace", "color": "#73eff7", "align": "center" },
      "size": { "w": 160, "h": 24 },
      "position": { "x": 400, "y": 10 },
      "tags": ["hud"],
      "layer": 100
    },
    {
      "id": "hud-lives",
      "sprite": { "kind": "text", "bind": "lives", "text": "3", "font": "20px monospace", "color": "#ff6b6b", "align": "right" },
      "size": { "w": 120, "h": 24 },
      "position": { "x": 668, "y": 10 },
      "tags": ["hud"],
      "layer": 100
    }
  ],
  "systems": [
    { "type": "aabb-collision", "params": { "pairs": [["ball", "paddle"], ["ball", "breakable"], ["ball", "killzone"]] } },
    { "type": "format-binding", "part": "format-binding@1.0.0", "params": { "bindings": [{ "from": "level", "template": "LEVEL {v}", "to": "levelDisplay" }] } },
    { "type": "score", "part": "score@1.0.0", "params": { "scoreKey": "score", "highKey": "best", "persist": false } },
    {
      "type": "lives-respawn",
      "part": "lives-respawn@1.0.0",
      "params": {
        "startLives": "$cfg.startLives",
        "watchTag": "ball",
        "respawnDelay": "$cfg.respawnDelay",
        "respawnPosition": { "x": 393, "y": 400 },
        "prototype": {
          "id": "ball",
          "sprite": { "kind": "shape", "shape": "circle", "color": "#ffcd75" },
          "size": { "w": 14, "h": 14 },
          "tags": ["ball"],
          "layer": 4,
          "behaviors": [
            { "type": "bounce-world-edges", "params": { "edges": ["top", "left", "right"], "restitution": "$cfg.wallRestitution" } },
            { "type": "reflect-on-hit", "params": { "tag": "paddle", "axis": "y", "english": "$cfg.paddleEnglish", "speedScale": "$cfg.paddleSpeedup", "maxSpeed": "$cfg.ballMaxSpeed" } },
            { "type": "reflect-on-hit", "params": { "tag": "breakable", "axis": "auto" } },
            { "type": "contact-damage", "part": "contact-damage@1.0.0", "params": { "targetTag": "breakable", "damage": "$cfg.ballDamage", "cooldown": "$cfg.ballHitCooldown" } },
            { "type": "velocity", "params": { "vx": "$cfg.ballSpeedX", "vy": "$cfg.ballSpeedY" } },
            { "type": "scale-by-state", "part": "scale-by-state@1.0.0", "params": { "target": "velocity", "mode": "once", "levelKey": "level", "perLevel": "$cfg.ballSpeedPerLevel" } }
          ]
        }
      }
    },
    { "type": "level-progression", "part": "level-progression@1.0.0", "params": { "levelKey": "clearLevel", "mode": "clearTag", "clearTag": "breakable", "event": "level-cleared" } },
    { "type": "persistence", "params": {} },
    { "type": "explosion", "params": { "event": "block-broken", "colors": ["#b13e53", "#ef7d57", "#ffcd75", "#a7f070", "#41a6f6"] } }
  ],
  "flow": { "on": { "level-cleared": "@next", "gameover": "over" }, "persist": ["score", "best", "lives"] }
}
