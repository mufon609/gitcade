  "background": "#07060c",
  "entities": [
    {
      "id": "gameover-text",
      "sprite": { "kind": "text", "text": "CRASHED", "font": "56px monospace", "color": "#b13e53", "align": "center" },
      "size": { "w": 500, "h": 56 },
      "position": { "x": 400, "y": 160 },
      "tags": ["ui"],
      "layer": 10
    },
    {
      "id": "score-label",
      "sprite": { "kind": "text", "text": "SCORE", "font": "16px monospace", "color": "#6a7196", "align": "center" },
      "size": { "w": 200, "h": 20 },
      "position": { "x": 280, "y": 280 },
      "tags": ["ui"],
      "layer": 10
    },
    {
      "id": "score-value",
      "sprite": { "kind": "text", "bind": "scoreDisplay", "text": "0", "font": "40px monospace", "color": "#f4f4f4", "align": "center" },
      "size": { "w": 200, "h": 44 },
      "position": { "x": 280, "y": 306 },
      "tags": ["ui"],
      "layer": 10
    },
    {
      "id": "best-label",
      "sprite": { "kind": "text", "text": "BEST", "font": "16px monospace", "color": "#6a7196", "align": "center" },
      "size": { "w": 200, "h": 20 },
      "position": { "x": 520, "y": 280 },
      "tags": ["ui"],
      "layer": 10
    },
    {
      "id": "best-value",
      "sprite": { "kind": "text", "bind": "bestDisplay", "text": "0", "font": "40px monospace", "color": "#ffcd75", "align": "center" },
      "size": { "w": 200, "h": 44 },
      "position": { "x": 520, "y": 306 },
      "tags": ["ui"],
      "layer": 10
    },
    {
      "id": "retry-prompt",
      "sprite": { "kind": "text", "text": "↻  TAP or press ENTER to fly again", "font": "18px monospace", "color": "#f4f4f4", "align": "center" },
      "size": { "w": 600, "h": 22 },
      "position": { "x": 400, "y": 430 },
      "tags": ["ui"],
      "layer": 10
    },
    {
      "id": "retry-btn",
      "sprite": { "kind": "none" },
      "size": { "w": 800, "h": 600 },
      "position": { "x": 0, "y": 0 },
      "tags": ["ui"],
      "layer": 999,
      "behaviors": [{ "type": "tap-emit", "params": { "emitOnTap": "retry" } }, { "type": "key-emit", "part": "key-emit@1.0.0", "params": { "keys": ["Enter", "Space"], "emitOnKey": "retry" } }]
    }
  ],
  "systems": [
    { "type": "persistence", "params": {} },
    {
      "type": "format-binding",
      "part": "format-binding@1.0.0",
      "params": {
        "bindings": [
          { "from": "score", "format": "floor", "to": "scoreDisplay" },
          { "from": "best", "format": "floor", "to": "bestDisplay" }
        ]
      }
    }
  ],
  "flow": {
    "on": { "retry": "play" },
    "persist": ["best", "bestDisplay"]
  }
}
