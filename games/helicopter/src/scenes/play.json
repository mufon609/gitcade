{
  "id": "play",
  "size": { "width": 800, "height": 600 },
  "background": {
    "color": "#0b0b16",
    "layers": [{ "src": "assets/backgrounds/starfield.png", "scrollX": -70 }]
  },
  "entities": [
    {
      "id": "player",
      "sprite": { "kind": "image", "src": "assets/sprites/player-ship.png" },
      "size": { "w": 40, "h": 24 },
      "position": { "x": 140, "y": 280 },
      "tags": ["player"],
      "layer": 5,
      "behaviors": [
        { "type": "thrust-lift", "params": { "thrustAction": "thrust", "thrust": "$cfg.thrust", "gravity": "$cfg.gravity", "maxUp": "$cfg.maxUp", "maxDown": "$cfg.maxDown" } },
        { "type": "velocity", "params": {} },
        { "type": "face-angle", "part": "face-angle@1.0.0", "params": { "mode": "tilt", "axis": "vy", "tiltPerVel": "$cfg.heliTiltPerVel", "maxTilt": "$cfg.heliMaxTilt" } },
        { "type": "trail", "params": { "color": "#ffcd75" } }
      ]
    },
    {
      "id": "wall-top",
      "sprite": { "kind": "shape", "shape": "rect", "color": "#1a1c2c" },
      "size": { "w": 800, "h": 18 }, "position": { "x": 0, "y": 0 }, "tags": ["wall"], "layer": 6,
      "behaviors": [{ "type": "trigger-zone", "part": "trigger-zone@1.0.0", "params": { "tag": "player", "enterEvent": "crash", "sound": "explode" } }]
    },
    {
      "id": "wall-bottom",
      "sprite": { "kind": "shape", "shape": "rect", "color": "#1a1c2c" },
      "size": { "w": 800, "h": 18 }, "position": { "x": 0, "y": 582 }, "tags": ["wall"], "layer": 6,
      "behaviors": [{ "type": "trigger-zone", "part": "trigger-zone@1.0.0", "params": { "tag": "player", "enterEvent": "crash", "sound": "explode" } }]
    },
    {
      "id": "hud-score",
      "sprite": { "kind": "text", "bind": "scoreDisplay", "text": "0", "font": "20px monospace", "color": "#f4f4f4", "align": "left" },
      "size": { "w": 200, "h": 24 }, "position": { "x": 60, "y": 10 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-level-label",
      "sprite": { "kind": "text", "text": "LVL", "font": "13px monospace", "color": "#6a7196", "align": "left" },
      "size": { "w": 36, "h": 16 }, "position": { "x": 632, "y": 14 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-level",
      "sprite": { "kind": "text", "bind": "level", "text": "1", "font": "20px monospace", "color": "#41a6f6", "align": "left" },
      "size": { "w": 40, "h": 24 }, "position": { "x": 672, "y": 10 }, "tags": ["hud"], "layer": 100, "behaviors": []
    }
  ],
  "systems": [
    {
      "type": "input-actions",
      "part": "input-actions@1.0.0",
      "params": {
        "bindings": {
          "thrust": { "keys": ["Space"], "rect": { "x": 0, "y": 0, "w": 800, "h": 600 } }
        }
      }
    },
    { "type": "aabb-collision", "params": { "pairs": [["player", "wall"], ["player", "obstacle"]] } },
    {
      "type": "format-binding",
      "part": "format-binding@1.0.0",
      "params": {
        "bindings": [
          { "from": "score", "format": "floor", "to": "scoreDisplay" },
          { "from": "best", "format": "floor", "to": "bestDisplay" }
        ]
      }
    },
    {
      "type": "wave-spawner",
      "part": "wave-spawner@1.1.0",
      "params": {
        "interval": "$cfg.spawnInterval",
        "waveSize": "$cfg.waveSize",
        "waveSizeGrowth": "$cfg.waveSizeGrowth",
        "waveDelay": "$cfg.waveDelay",
        "maxWaves": "$cfg.maxWaves",
        "maxAlive": "$cfg.maxAlive",
        "startDelay": "$cfg.startDelay",
        "countTag": "obstacle",
        "waveKey": "wave",
        "advanceOnClear": false,
        "levelKey": "level",
        "intervalPerLevel": "$cfg.densityRampPerLevel",
        "spawnPoints": [{ "x": 820, "y": 60 }, { "x": 820, "y": 420 }, { "x": 820, "y": 220 }, { "x": 820, "y": 90 }, { "x": 820, "y": 360 }],
        "prototype": {
          "id": "obstacle",
          "sprite": { "kind": "shape", "shape": "rect", "color": "#3b5dc9" },
          "size": { "w": 54, "h": 150 },
          "tags": ["obstacle"],
          "layer": 3,
          "behaviors": [
            { "type": "scale-by-state", "params": { "target": "velocity", "mode": "set", "baseX": "$cfg.scrollVx", "levelKey": "level", "perLevel": "$cfg.speedRampPerLevel" } },
            { "type": "velocity", "params": {} },
            { "type": "trigger-zone", "part": "trigger-zone@1.0.0", "params": { "tag": "player", "enterEvent": "crash", "sound": "explode" } },
            { "type": "health-and-death", "params": { "lifespan": "$cfg.obstacleLife", "deathSound": "" } }
          ]
        }
      }
    },
    { "type": "currency", "part": "currency@1.0.0", "params": { "currencyKey": "score", "startAmount": "$cfg.startScore", "passiveIncome": "$cfg.pointsPerSec" } },
    { "type": "score", "part": "score@1.0.0", "params": { "scoreKey": "score", "highKey": "best", "persist": false } },
    {
      "type": "level-progression",
      "part": "level-progression@1.0.0",
      "params": {
        "levelKey": "level",
        "mode": "scoreGte",
        "scoreKey": "score",
        "threshold": "$cfg.levelThreshold",
        "thresholdGrowth": "$cfg.levelThresholdGrowth",
        "maxLevel": "$cfg.maxLevel",
        "event": "level-up"
      }
    },
    { "type": "explosion", "part": "explosion@1.0.0", "params": { "event": "crash" } },
    { "type": "persistence", "params": {} }
  ],
  "flow": {
    "on": { "crash": "over" },
    "persist": ["score", "best", "scoreDisplay", "bestDisplay", "level"]
  }
}
