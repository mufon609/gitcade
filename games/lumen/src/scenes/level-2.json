    {
      "id": "mote-0",
      "sprite": {
        "kind": "sheet",
        "src": "assets/lumen/mote.png",
        "frameWidth": 16,
        "frameHeight": 16,
        "frameCount": 4,
        "fps": 10,
        "animations": {
          "spin": {
            "from": 0,
            "to": 3
          }
        }
      },
      "size": {
        "w": 16,
        "h": 16
      },
      "position": {
        "x": 264,
        "y": 360
      },
      "tags": [
        "mote"
      ],
      "layer": 4,
      "behaviors": [
        {
          "type": "collect-on-touch",
          "part": "collect-on-touch@1.0.0",
          "params": {
            "collectorTag": "player",
            "value": "$cfg.moteValue",
            "scoreKey": "motes",
            "kind": "mote",
            "sound": "collect"
          }
        },
        {
          "type": "sprite-animate",
          "params": {
            "play": "spin"
          }
        },
        {
          "type": "tween",
          "part": "tween@1.0.0",
          "params": {
            "property": "scale",
            "from": 1,
            "to": 1.2,
            "duration": "$cfg.moteBobDuration",
            "easing": "in-out-quad",
            "loop": "pingpong"
