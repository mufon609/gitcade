{
  "id": "play",
  "size": { "width": 800, "height": 600 },
  "background": {
    "color": "#0b0b16",
    "layers": [{ "src": "assets/backgrounds/starfield.png", "scrollX": 0, "scrollY": 0 }]
  },
  "entities": [
    {
      "id": "playfield-frame",
      "sprite": { "kind": "shape", "shape": "rect", "color": "rgba(0,0,0,0)", "stroke": "#3b5dc9", "strokeWidth": 2 },
      "size": { "w": 798, "h": 598 },
      "position": { "x": 1, "y": 1 },
      "tags": ["decor"],
      "layer": 1,
      "behaviors": []
    },
    {
      "id": "head",
      "sprite": { "kind": "sheet", "src": "assets/sprites/player-blob.png", "frameWidth": 32, "frameHeight": 32, "frameCount": 2, "fps": 4, "animations": { "idle": { "from": 0, "to": 1 } } },
      "size": { "w": 20, "h": 20 },
      "position": { "x": 400, "y": 300 },
      "tags": ["head", "snake-cell"],
      "layer": 4,
      "behaviors": [
        { "type": "sprite-animate", "params": { "play": "idle" } },
        { "type": "move-grid-step", "part": "move-grid-step@1.0.0", "params": { "tileSize": "$cfg.tileSize", "stepInterval": "$cfg.stepInterval", "continuous": true, "snap": true } },
        { "type": "snake-guard", "params": { "stateKey": "__snake", "tileSize": "$cfg.tileSize", "gameOverEvent": "snake-dead" } }
      ]
    },
    {
      "id": "hud-score-label",
      "sprite": { "kind": "text", "text": "SCORE", "font": "11px monospace", "color": "#6a7196", "align": "center" },
      "size": { "w": 120, "h": 14 },
      "position": { "x": 400, "y": 10 },
      "tags": ["hud"],
      "layer": 100,
      "behaviors": []
    },
    {
      "id": "hud-score",
      "sprite": { "kind": "text", "bind": "score", "text": "0", "font": "22px monospace", "color": "#f4f4f4", "align": "center" },
      "size": { "w": 120, "h": 26 },
      "position": { "x": 400, "y": 24 },
      "tags": ["hud"],
      "layer": 100,
      "behaviors": []
    }
  ],
  "systems": [
    { "type": "aabb-collision", "params": { "pairs": [["head", "food"]] } },
    {
      "type": "place-on-free-cell",
      "params": {
        "trigger": "place-food",
        "tileSize": "$cfg.tileSize",
        "occupiedTag": "snake-cell",
        "excludeTags": ["imminent"],
        "prototype": {
          "id": "food",
          "sprite": { "kind": "sheet", "src": "assets/sprites/coin.png", "frameWidth": 16, "frameHeight": 16, "frameCount": 4, "fps": 8, "animations": { "spin": { "from": 0, "to": 3 } } },
          "size": { "w": 20, "h": 20 },
          "tags": ["food", "pickup"],
          "layer": 2,
          "behaviors": [
            { "type": "sprite-animate", "params": { "play": "spin" } },
            { "type": "collect-on-touch", "part": "collect-on-touch@1.0.0", "params": { "collectorTag": "head", "value": "$cfg.foodValue", "scoreKey": "score", "kind": "coin", "sound": "collect" } }
          ]
        }
      }
    },
    { "type": "score", "part": "score@1.0.0", "params": { "scoreKey": "score", "highKey": "best", "persist": false } },
    {
      "type": "sparkle",
      "part": "sparkle@1.0.0",
      "params": { "event": "collect", "colors": ["#ffcd75", "#f4f4f4", "#a7f070"] }
    },
    {
      "type": "snake-body",
      "params": {
        "headTag": "head",
        "segmentTag": "snake-body",
        "foodTag": "food",
        "placeEvent": "place-food",
        "tileSize": "$cfg.tileSize",
        "startLength": "$cfg.startLength",
        "growBy": "$cfg.growBy",
        "startDir": { "x": 1, "y": 0 },
        "scoreKey": "score",
        "foodValue": "$cfg.foodValue",
        "gameOverEvent": "snake-dead",
        "stateKey": "__snake",
        "segmentPrototype": {
          "id": "seg",
          "sprite": { "kind": "image", "src": "assets/sprites/snake-segment.png" },
          "size": { "w": 20, "h": 20 },
          "tags": ["snake-body", "snake-cell"],
          "layer": 3,
          "behaviors": []
        }
      }
    },
    { "type": "persistence", "params": {} }
  ],
  "flow": {
    "on": { "snake-dead": "over" },
    "persist": ["score", "best"]
  }
}
