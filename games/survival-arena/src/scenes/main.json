{
  "id": "main",
  "size": { "width": 800, "height": 600 },
  "background": "#0b0b16",
  "entities": [
    {
      "id": "player",
      "sprite": { "kind": "sheet", "src": "assets/sprites/player-blob.png", "frameWidth": 32, "frameHeight": 32, "frameCount": 2, "fps": 4, "animations": { "idle": { "from": 0, "to": 1 } } },
      "size": { "w": 30, "h": 30 },
      "position": { "x": 385, "y": 285 },
      "tags": ["player"],
      "layer": 5,
      "behaviors": [
        { "type": "sprite-animate", "params": { "play": "idle" } },
        { "type": "move-topdown-360", "part": "move-topdown-360@1.0.0", "params": { "speed": "$cfg.playerSpeed", "pointerFollow": true } },
        { "type": "velocity", "params": {} },
        { "type": "clamp-to-world", "params": { "axis": "both", "padding": 8 } },
        {
          "type": "shoot",
          "part": "shoot@1.0.0",
          "params": {
            "auto": true,
            "aimTag": "enemy",
            "projectileSpeed": "$cfg.bulletSpeed",
            "cooldown": "$cfg.fireCooldown",
            "sound": "shoot",
            "projectile": {
              "id": "bullet",
              "sprite": { "kind": "image", "src": "assets/sprites/bullet.png" },
              "size": { "w": 10, "h": 10 },
              "tags": ["bullet"],
              "layer": 4,
              "behaviors": [
                { "type": "velocity", "params": {} },
                { "type": "contact-damage", "params": { "targetTag": "enemy", "damage": "$cfg.bulletDamage", "selfDestruct": true } },
                { "type": "health-and-death", "params": { "hp": "$cfg.bulletHp", "lifespan": "$cfg.bulletLifespan", "deathSound": "" } }
              ]
            }
          }
        },
        { "type": "health-and-death", "part": "health-and-death@1.0.0", "params": { "hp": "$cfg.playerHp", "deathEvent": "player-died", "deathSound": "lose", "destroyOnDeath": false, "tallyKey": "playerDeaths" } }
      ]
    },
    {
      "id": "hud-score",
      "sprite": { "kind": "text", "bind": "score", "text": "0", "font": "20px monospace", "color": "#f4f4f4", "align": "left" },
      "size": { "w": 160, "h": 24 }, "position": { "x": 12, "y": 10 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-wave",
      "sprite": { "kind": "text", "bind": "wave", "text": "1", "font": "20px monospace", "color": "#41a6f6", "align": "center" },
      "size": { "w": 160, "h": 24 }, "position": { "x": 400, "y": 10 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-timer",
      "sprite": { "kind": "text", "bind": "clock", "text": "75", "font": "20px monospace", "color": "#ffcd75", "align": "right" },
      "size": { "w": 120, "h": 24 }, "position": { "x": 668, "y": 10 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-health-bar",
      "sprite": { "kind": "shape", "shape": "rect", "color": "#a7f070" },
      "size": { "w": 160, "h": 12 }, "position": { "x": 12, "y": 40 }, "tags": ["hud"], "layer": 100,
      "behaviors": [{ "type": "hud-bar", "params": { "valueKey": "hp", "maxKey": "maxHp", "width": 160 } }]
    }
  ],
  "systems": [
    { "type": "aabb-collision", "params": { "pairs": [["player", "enemy"], ["enemy", "bullet"]] } },
    {
      "type": "wave-spawner",
      "part": "wave-spawner@1.0.0",
      "params": {
        "interval": "$cfg.spawnInterval",
        "waveSize": "$cfg.waveSize",
        "waveSizeGrowth": "$cfg.waveSizeGrowth",
        "waveDelay": "$cfg.waveDelay",
        "maxWaves": "$cfg.maxWaves",
        "maxAlive": "$cfg.maxAlive",
        "startDelay": "$cfg.startDelay",
        "countTag": "enemy",
        "waveKey": "wave",
        "advanceOnClear": false,
        "spawnPoints": [{ "x": 40, "y": 40 }, { "x": 760, "y": 40 }, { "x": 40, "y": 560 }, { "x": 760, "y": 560 }, { "x": 400, "y": 30 }, { "x": 400, "y": 570 }],
        "prototype": {
          "id": "enemy",
          "sprite": { "kind": "image", "src": "assets/sprites/enemy-chaser.png" },
          "size": { "w": 26, "h": 26 },
          "tags": ["enemy"],
          "layer": 3,
          "behaviors": [
            { "type": "ai-chase", "params": { "targetTag": "player", "speed": "$cfg.enemySpeed" } },
            { "type": "velocity", "params": {} },
            { "type": "contact-damage", "params": { "targetTag": "player", "damage": "$cfg.enemyDamage", "cooldown": "$cfg.damageCooldown" } },
            { "type": "health-and-death", "params": { "hp": "$cfg.enemyHp", "tallyKey": "score", "tallyAmount": "$cfg.killScore", "deathEvent": "enemy-died", "deathSound": "explode" } }
          ]
        }
      }
    },
    { "type": "timer-countdown", "part": "timer-countdown@1.0.0", "params": { "duration": "$cfg.surviveTime", "timeKey": "timeLeft", "event": "survived", "onExpire": "win" } },
    { "type": "win-lose-conditions", "part": "win-lose-conditions@1.0.0", "params": { "conditions": [{ "key": "playerDeaths", "cmp": "gte", "value": "$cfg.deathsToLose", "outcome": "lose", "winner": "swarm" }] } },
    { "type": "score", "part": "score@1.0.0", "params": { "scoreKey": "score", "highKey": "highScore", "storageKey": "arenaHigh", "persist": true } },
    { "type": "explosion", "part": "explosion@1.0.0", "params": { "event": "enemy-died" } }
  ]
}
