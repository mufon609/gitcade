{
  "id": "play",
  "size": { "width": 800, "height": 600 },
  "background": {
    "color": "#0b0b16",
    "layers": [{ "src": "assets/backgrounds/starfield.png", "scrollX": 0, "scrollY": 0 }]
  },
  "entities": [
    {
      "id": "arena-frame",
      "sprite": { "kind": "shape", "shape": "rect", "color": "rgba(0,0,0,0)", "stroke": "#3b5dc9", "strokeWidth": 2 },
      "size": { "w": 798, "h": 598 },
      "position": { "x": 1, "y": 1 },
      "tags": ["decor"],
      "layer": 1,
      "behaviors": []
    },
    {
      "id": "player",
      "sprite": { "kind": "sheet", "src": "assets/sprites/player-blob.png", "frameWidth": 32, "frameHeight": 32, "frameCount": 2, "fps": 4, "animations": { "idle": { "from": 0, "to": 1 } } },
      "size": { "w": 30, "h": 30 },
      "position": { "x": 385, "y": 285 },
      "tags": ["player"],
      "layer": 5,
      "behaviors": [
        { "type": "sprite-animate", "params": { "play": "idle" } },
        { "type": "move-topdown-360", "part": "move-topdown-360@1.0.0", "params": { "speed": "$cfg.playerSpeed", "pointerFollow": true } },
        { "type": "velocity", "params": {} },
        { "type": "clamp-to-world", "params": { "axis": "both", "padding": 8 } },
        {
          "type": "shoot",
          "part": "shoot@1.0.0",
          "params": {
            "auto": true,
            "aimTag": "enemy",
            "projectileSpeed": "$cfg.bulletSpeed",
            "cooldown": "$cfg.fireCooldown",
            "sound": "shoot",
            "projectile": {
              "id": "bullet",
              "sprite": { "kind": "image", "src": "assets/sprites/bullet.png" },
              "size": { "w": 10, "h": 10 },
              "tags": ["bullet"],
              "layer": 4,
              "behaviors": [
                { "type": "velocity", "params": {} },
                { "type": "trail", "params": { "color": "#ffcd75", "rate": "$cfg.bulletTrailRate", "ttl": "$cfg.bulletTrailTtl", "size": 3 } },
                { "type": "contact-damage", "params": { "targetTag": "enemy", "damage": "$cfg.bulletDamage", "selfDestruct": true } },
                { "type": "health-and-death", "params": { "hp": "$cfg.bulletHp", "lifespan": "$cfg.bulletLifespan", "deathSound": "" } }
              ]
            }
          }
        },
        { "type": "health-and-death", "part": "health-and-death@1.0.0", "params": { "hp": "$cfg.playerHp", "deathEvent": "player-died", "deathSound": "lose", "destroyOnDeath": false, "tallyKey": "playerDeaths" } }
      ]
    },
    {
      "id": "hud-score",
      "sprite": { "kind": "text", "bind": "score", "text": "0", "font": "20px monospace", "color": "#f4f4f4", "align": "left" },
      "size": { "w": 160, "h": 24 }, "position": { "x": 60, "y": 10 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-wave-label",
      "sprite": { "kind": "text", "text": "WAVE", "font": "13px monospace", "color": "#6a7196", "align": "center" },
      "size": { "w": 60, "h": 16 }, "position": { "x": 400, "y": 8 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-wave",
      "sprite": { "kind": "text", "bind": "wave", "text": "1", "font": "20px monospace", "color": "#41a6f6", "align": "center" },
      "size": { "w": 60, "h": 24 }, "position": { "x": 400, "y": 22 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-level-label",
      "sprite": { "kind": "text", "text": "LVL", "font": "13px monospace", "color": "#6a7196", "align": "center" },
      "size": { "w": 40, "h": 16 }, "position": { "x": 520, "y": 8 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-level",
      "sprite": { "kind": "text", "bind": "level", "text": "1", "font": "20px monospace", "color": "#b13e53", "align": "center" },
      "size": { "w": 40, "h": 24 }, "position": { "x": 520, "y": 22 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-timer",
      "sprite": { "kind": "text", "bind": "clock", "text": "75", "font": "20px monospace", "color": "#ffcd75", "align": "right" },
      "size": { "w": 120, "h": 24 }, "position": { "x": 668, "y": 10 }, "tags": ["hud"], "layer": 100, "behaviors": []
    },
    {
      "id": "hud-health-bar",
      "sprite": { "kind": "shape", "shape": "rect", "color": "#a7f070" },
      "size": { "w": 160, "h": 12 }, "position": { "x": 60, "y": 40 }, "tags": ["hud"], "layer": 100,
      "behaviors": [{ "type": "hud-bar", "params": { "valueKey": "hp", "maxKey": "maxHp", "width": 160 } }]
    }
  ],
  "systems": [
    { "type": "aabb-collision", "params": { "pairs": [["player", "enemy"], ["enemy", "bullet"]] } },
    {
      "type": "wave-spawner",
      "part": "wave-spawner@1.0.0",
      "params": {
        "interval": "$cfg.spawnInterval",
        "waveSize": "$cfg.waveSize",
        "waveSizeGrowth": "$cfg.waveSizeGrowth",
        "waveDelay": "$cfg.waveDelay",
        "maxWaves": "$cfg.maxWaves",
        "maxAlive": "$cfg.maxAlive",
        "startDelay": "$cfg.startDelay",
        "countTag": "enemy",
        "waveKey": "wave",
        "advanceOnClear": false,
        "placement": "free-cell",
        "tileSize": "$cfg.enemyTileSize",
        "occupiedTag": "enemy",
        "spawnPoints": [{ "x": 40, "y": 40 }, { "x": 760, "y": 40 }, { "x": 40, "y": 560 }, { "x": 760, "y": 560 }, { "x": 400, "y": 30 }, { "x": 400, "y": 570 }],
        "prototype": {
          "id": "enemy",
          "sprite": { "kind": "image", "src": "assets/sprites/enemy-chaser.png" },
          "size": { "w": 26, "h": 26 },
          "tags": ["enemy"],
          "layer": 3,
          "behaviors": [
            { "type": "ai-chase", "params": { "targetTag": "player", "speed": "$cfg.enemySpeed" } },
            { "type": "scale-by-state", "params": { "target": "velocity", "mode": "multiply", "levelKey": "level", "perLevel": "$cfg.speedPerLevel" } },
            { "type": "velocity", "params": {} },
            { "type": "contact-damage", "params": { "targetTag": "player", "damage": "$cfg.enemyDamage", "cooldown": "$cfg.damageCooldown" } },
            { "type": "health-and-death", "params": { "hp": "$cfg.enemyHp", "tallyKey": "score", "tallyAmount": "$cfg.killScore", "deathEvent": "enemy-died", "deathSound": "explode" } },
            { "type": "scale-by-state", "params": { "target": "state:hp", "mode": "once", "base": "$cfg.enemyHp", "levelKey": "level", "perLevel": "$cfg.hpPerLevel" } }
          ]
        }
      }
    },
    { "type": "timer-countdown", "part": "timer-countdown@1.0.0", "params": { "duration": "$cfg.surviveTime", "timeKey": "timeLeft", "event": "survived", "onExpire": "win" } },
    { "type": "win-lose-conditions", "part": "win-lose-conditions@1.1.0", "params": { "conditions": [{ "key": "playerDeaths", "cmp": "gte", "value": "$cfg.deathsToLose", "outcome": "lose", "winner": "swarm" }] } },
    { "type": "score", "part": "score@1.0.0", "params": { "scoreKey": "score", "highKey": "best", "persist": false } },
    {
      "type": "level-progression",
      "part": "level-progression@1.0.0",
      "params": {
        "levelKey": "level",
        "mode": "scoreGte",
        "scoreKey": "score",
        "threshold": "$cfg.levelThreshold",
        "thresholdGrowth": "$cfg.levelThresholdGrowth",
        "maxLevel": "$cfg.maxLevel",
        "event": "level-up"
      }
    },
    { "type": "explosion", "part": "explosion@1.0.0", "params": { "event": "enemy-died", "count": "$cfg.killBurstCount", "speed": "$cfg.killBurstSpeed", "ttl": "$cfg.killBurstTtl", "size": 5 } },
    { "type": "explosion", "part": "explosion@1.0.0", "params": { "event": "player-died", "key": "explosion:player", "count": "$cfg.deathBurstCount", "speed": "$cfg.deathBurstSpeed", "ttl": "$cfg.deathBurstTtl", "size": 7, "colors": ["#b13e53", "#ef7d57", "#ffcd75", "#f4f4f4"] } },
    { "type": "sparkle", "part": "sparkle@1.0.0", "params": { "event": "level-up", "count": "$cfg.levelBurstCount", "speed": "$cfg.levelBurstSpeed", "ttl": "$cfg.levelBurstTtl", "size": 5, "colors": ["#41a6f6", "#73eff7", "#f4f4f4"] } },
    { "type": "persistence", "params": {} },
    {
      "type": "format-binding",
      "part": "format-binding@1.0.0",
      "params": {
        "bindings": [
          { "from": "hp", "fromEntity": "player", "format": "round", "to": "hp" },
          { "constant": "$cfg.playerHp", "to": "maxHp" },
          { "from": "timeLeft", "format": "ceil", "to": "clock" }
        ]
      }
    }
  ],
  "flow": {
    "on": { "gameover": "over" },
    "persist": ["score", "best", "outcome"]
  }
}
