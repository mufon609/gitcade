{
  "id": "over",
  "size": { "width": 800, "height": 600 },
  "background": "#0b0b16",
  "entities": [
    {
      "id": "retry-target",
      "sprite": { "kind": "shape", "shape": "rect", "color": "rgba(0,0,0,0)" },
      "size": { "w": 800, "h": 600 },
      "position": { "x": 0, "y": 0 },
      "tags": ["ui"],
      "layer": 999,
      "behaviors": [{ "type": "tap-emit", "params": { "emitOnTap": "retry" } }, { "type": "key-emit", "part": "key-emit@1.0.0", "params": { "keys": ["Enter", "Space"], "emitOnKey": "retry" } }]
    },
    {
      "id": "over-heading",
      "sprite": { "kind": "text", "bind": "outcomeTitle", "text": "Game Over", "font": "44px monospace", "color": "#ffcd75", "align": "center" },
      "size": { "w": 760, "h": 52 }, "position": { "x": 400, "y": 200 }, "tags": ["ui"], "layer": 100, "behaviors": []
    },
    {
      "id": "over-summary",
      "sprite": { "kind": "text", "bind": "outcomeSummary", "text": "", "font": "20px monospace", "color": "#41a6f6", "align": "center" },
      "size": { "w": 760, "h": 26 }, "position": { "x": 400, "y": 280 }, "tags": ["ui"], "layer": 100, "behaviors": []
    },
    {
      "id": "over-best",
      "sprite": { "kind": "text", "bind": "bestWaveHud", "text": "", "font": "18px monospace", "color": "#a7f070", "align": "center" },
      "size": { "w": 760, "h": 24 }, "position": { "x": 400, "y": 330 }, "tags": ["ui"], "layer": 100, "behaviors": []
    },
    {
      "id": "over-retry",
      "sprite": { "kind": "text", "text": "↻  Tap anywhere to play again", "font": "24px monospace", "color": "#f4f4f4", "align": "center" },
      "size": { "w": 760, "h": 28 }, "position": { "x": 400, "y": 420 }, "tags": ["ui"], "layer": 100, "behaviors": []
    }
  ],
  "systems": [
    { "type": "persistence", "params": {} },
    {
      "type": "format-binding",
      "part": "format-binding@1.0.0",
      "params": {
        "bindings": [
          { "from": "bestWave", "emptyWhenZero": true, "template": "Best: wave {v}", "to": "bestWaveHud" },
          { "from": "outcome", "map": { "win": "The line held! 🛡️" }, "mapDefault": "Overrun", "to": "outcomeTitle" }
        ]
      }
    }
  ],
  "flow": {
    "on": { "retry": "play" },
    "persist": ["bestWave"]
  }
}
