{
  "name": "gitcade",
  "version": "0.0.0",
  "private": true,
  "description": "Git for Gamers — open-source, AI-built, community-governed browser games.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "packages/library/proofs/*",
    "games/*",
    "platform/*",
    "templates/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "validate:pong": "gitcade validate examples/pong",
    "validate:proofs": "for d in packages/library/proofs/*/; do gitcade validate \"$d\" || exit 1; done"
  }
}
