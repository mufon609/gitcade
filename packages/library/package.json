{
  "name": "@gitcade/library",
  "version": "1.11.0",
  "description": "GitCade Component Library — game-agnostic, param-driven parts for the GitCade SDK: behaviors, systems, entities, UI, FX, and generated assets (art, audio, tilesets).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "gitcade",
    "game-components",
    "behaviors",
    "systems",
    "entity-component"
  ],
  "homepage": "https://github.com/mufon609/gitcade",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mufon609/gitcade.git",
    "directory": "packages/library"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./CATALOG.json": "./CATALOG.json",
    "./catalog.schema.json": "./catalog.schema.json",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "parts",
    "assets",
    "scripts/gen-assets.ts",
    "CATALOG.json",
    "catalog.schema.json",
    "README.md",
    "CONVENTIONS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "gen-assets": "node scripts/gen-assets.ts",
    "catalog": "node scripts/build-catalog.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run catalog && npm run build"
  },
  "peerDependencies": {
    "@gitcade/sdk": "^1.10.0"
  },
  "devDependencies": {
    "@gitcade/sdk": "^1.10.0",
    "@types/node": "^22.7.0",
    "ajv": "^8.17.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
