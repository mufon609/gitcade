{
  "id": "move-platformer",
  "kind": "behavior",
  "version": "1.0.0",
  "category": "movement",
  "tags": ["movement", "player", "platformer", "gravity", "jump"],
  "license": "MIT",
  "description": "Side-scrolling locomotion: horizontal run, gravity, jump, and coyote-time. Sets velocity for a following velocity integrator.",
  "dependencies": ["velocity"],
  "params": {
    "moveSpeed": { "type": "number", "balance": true, "description": "Horizontal run speed in px/sec." },
    "gravity": { "type": "number", "balance": true, "description": "Downward acceleration in px/sec²." },
    "jumpSpeed": { "type": "number", "balance": true, "description": "Upward jump launch velocity in px/sec." },
    "coyoteTime": { "type": "number", "balance": true, "description": "Post-ledge jump grace in seconds." },
    "maxFall": { "type": "number", "balance": true, "description": "Terminal fall speed in px/sec (0 = uncapped)." },
    "left": { "type": "array", "balance": false, "description": "Left key codes." },
    "right": { "type": "array", "balance": false, "description": "Right key codes." },
    "jump": { "type": "array", "balance": false, "description": "Jump key codes." },
    "groundTag": { "type": "string", "balance": false, "description": "Tag of solid ground entities." }
  },
  "definition": {
    "type": "move-platformer",
    "params": {
      "moveSpeed": "$cfg.playerSpeed",
      "gravity": "$cfg.gravity",
      "jumpSpeed": "$cfg.jumpSpeed",
      "coyoteTime": "$cfg.coyoteTime",
      "groundTag": "ground"
    }
  }
}
