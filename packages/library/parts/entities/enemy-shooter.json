{
  "id": "enemy-shooter",
  "kind": "entity",
  "version": "1.0.0",
  "category": "entities",
  "tags": ["enemy", "ai", "ranged", "turret"],
  "license": "CC-BY-4.0",
  "description": "A stationary ranged enemy: ai-aim-and-fire lobs enemy-bullets at the player within range, with health-and-death. The pressure source for arena/shmup genres.",
  "dependencies": ["ai-aim-and-fire", "velocity", "contact-damage", "health-and-death"],
  "definition": {
    "type": "enemy-shooter",
    "params": {
      "sprite": { "kind": "image", "src": "assets/sprites/enemy-shooter.png" },
      "size": { "w": 30, "h": 30 },
      "tags": ["enemy"],
      "layer": 3,
      "behaviors": [
        {
          "type": "ai-aim-and-fire",
          "params": {
            "targetTag": "player",
            "range": "$cfg.turretRange",
            "cooldown": "$cfg.turretCooldown",
            "projectileSpeed": "$cfg.turretBulletSpeed",
            "projectile": {
              "id": "enemy-bullet",
              "sprite": { "kind": "image", "src": "assets/sprites/bullet.png" },
              "size": { "w": 8, "h": 8 },
              "tags": ["enemy-bullet"],
              "layer": 3,
              "behaviors": [
                { "type": "velocity", "params": {} },
                { "type": "contact-damage", "params": { "targetTag": "player", "damage": "$cfg.turretBulletDamage", "selfDestruct": true } },
                { "type": "health-and-death", "params": { "hp": "$cfg.bulletHp", "lifespan": "$cfg.bulletLifespan", "deathSound": "" } }
              ]
            }
          }
        },
        { "type": "health-and-death", "params": { "hp": "$cfg.enemyHp", "tallyKey": "kills", "deathEvent": "enemy-died" } }
      ]
    }
  }
}
