{
  "id": "trail",
  "kind": "fx",
  "version": "1.0.0",
  "category": "fx",
  "tags": ["fx", "particles", "trail", "behavior"],
  "license": "MIT",
  "description": "A per-entity BEHAVIOR that drips a fading particle behind a moving entity at a fixed rate (projectiles, comets, dashes). Time-based, so density is frame-rate independent.",
  "dependencies": ["particle"],
  "params": {
    "rate": { "type": "number", "balance": true, "description": "Seconds between drips." },
    "ttl": { "type": "number", "balance": true, "description": "Particle lifetime (s)." },
    "size": { "type": "number", "balance": false, "description": "Particle box size in px (structural)." },
    "color": { "type": "string", "balance": false, "description": "Palette hex color." }
  },
  "definition": {
    "type": "trail",
    "params": {
      "rate": "$cfg.fxTrailRate",
      "ttl": "$cfg.fxTrailTtl",
      "size": 4,
      "color": "#41a6f6"
    }
  }
}
