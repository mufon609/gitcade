{
  "id": "main",
  "size": { "width": 800, "height": 600 },
  "background": "#0b0612",
  "entities": [
    { "id": "backdrop", "sprite": { "kind": "image", "src": "assets/backgrounds/starfield.png" }, "size": { "w": 800, "h": 600 }, "position": { "x": 0, "y": 0 }, "tags": [], "layer": 0, "behaviors": [] },

    { "id": "acc-tl", "sprite": { "kind": "sheet", "src": "assets/tilesets/space.png", "frameWidth": 16, "frameHeight": 16, "frameCount": 5, "fps": 1, "animations": { "accent": { "from": 3, "to": 3, "loop": false } } }, "size": { "w": 32, "h": 32 }, "position": { "x": 56, "y": 80 }, "tags": [], "layer": 0, "behaviors": [{ "type": "sprite-animate", "params": { "play": "accent" } }] },
    { "id": "acc-tr", "sprite": { "kind": "sheet", "src": "assets/tilesets/space.png", "frameWidth": 16, "frameHeight": 16, "frameCount": 5, "fps": 1, "animations": { "accent": { "from": 3, "to": 3, "loop": false } } }, "size": { "w": 32, "h": 32 }, "position": { "x": 712, "y": 80 }, "tags": [], "layer": 0, "behaviors": [{ "type": "sprite-animate", "params": { "play": "accent" } }] },
    { "id": "acc-bl", "sprite": { "kind": "sheet", "src": "assets/tilesets/space.png", "frameWidth": 16, "frameHeight": 16, "frameCount": 5, "fps": 1, "animations": { "accent": { "from": 3, "to": 3, "loop": false } } }, "size": { "w": 32, "h": 32 }, "position": { "x": 56, "y": 488 }, "tags": [], "layer": 0, "behaviors": [{ "type": "sprite-animate", "params": { "play": "accent" } }] },
    { "id": "acc-br", "sprite": { "kind": "sheet", "src": "assets/tilesets/space.png", "frameWidth": 16, "frameHeight": 16, "frameCount": 5, "fps": 1, "animations": { "accent": { "from": 3, "to": 3, "loop": false } } }, "size": { "w": 32, "h": 32 }, "position": { "x": 712, "y": 488 }, "tags": [], "layer": 0, "behaviors": [{ "type": "sprite-animate", "params": { "play": "accent" } }] },

    { "id": "coin1", "sprite": { "kind": "sheet", "src": "assets/sprites/coin.png", "frameWidth": 16, "frameHeight": 16, "frameCount": 4, "fps": 8, "animations": { "spin": { "from": 0, "to": 3 } } }, "size": { "w": 16, "h": 16 }, "position": { "x": 180, "y": 150 }, "tags": ["coin"], "layer": 2, "behaviors": [{ "type": "sprite-animate", "params": { "play": "spin" } }, { "type": "collect-on-touch", "params": { "collectorTag": "player", "value": "$cfg.coinValue", "scoreKey": "score", "kind": "coin" } }] },
    { "id": "coin2", "sprite": { "kind": "sheet", "src": "assets/sprites/coin.png", "frameWidth": 16, "frameHeight": 16, "frameCount": 4, "fps": 8, "animations": { "spin": { "from": 0, "to": 3 } } }, "size": { "w": 16, "h": 16 }, "position": { "x": 600, "y": 430 }, "tags": ["coin"], "layer": 2, "behaviors": [{ "type": "sprite-animate", "params": { "play": "spin" } }, { "type": "collect-on-touch", "params": { "collectorTag": "player", "value": "$cfg.coinValue", "scoreKey": "score", "kind": "coin" } }] },
    { "id": "coin3", "sprite": { "kind": "sheet", "src": "assets/sprites/coin.png", "frameWidth": 16, "frameHeight": 16, "frameCount": 4, "fps": 8, "animations": { "spin": { "from": 0, "to": 3 } } }, "size": { "w": 16, "h": 16 }, "position": { "x": 600, "y": 150 }, "tags": ["coin"], "layer": 2, "behaviors": [{ "type": "sprite-animate", "params": { "play": "spin" } }, { "type": "collect-on-touch", "params": { "collectorTag": "player", "value": "$cfg.coinValue", "scoreKey": "score", "kind": "coin" } }] },

    {
      "id": "player",
      "sprite": { "kind": "sheet", "src": "assets/sprites/player-blob.png", "frameWidth": 32, "frameHeight": 32, "frameCount": 2, "fps": 4, "animations": { "idle": { "from": 0, "to": 1 } } },
      "size": { "w": 32, "h": 32 },
      "position": { "x": 384, "y": 284 },
      "tags": ["player"],
      "layer": 4,
      "behaviors": [
        { "type": "sprite-animate", "params": { "play": "idle" } },
        { "type": "move-topdown-360", "params": { "speed": "$cfg.playerSpeed", "pointerFollow": false } },
        { "type": "velocity", "params": {} },
        { "type": "clamp-to-world", "params": { "padding": 8 } },
        { "type": "contact-damage", "params": { "targetTag": "enemy", "damage": "$cfg.playerThorns", "cooldown": "$cfg.thornsCooldown" } },
        { "type": "health-and-death", "params": { "hp": "$cfg.playerHp", "tallyKey": "playerDeaths", "deathEvent": "player-died", "deathSound": "lose", "destroyOnDeath": false } }
      ]
    },

    { "id": "hud-kills", "sprite": { "kind": "text", "bind": "kills", "text": "0", "font": "20px monospace", "color": "#f4f4f4", "align": "left" }, "size": { "w": 160, "h": 24 }, "position": { "x": 14, "y": 12 }, "tags": ["hud"], "layer": 100, "behaviors": [] },
    { "id": "hud-wave", "sprite": { "kind": "text", "bind": "wave", "text": "1", "font": "20px monospace", "color": "#41a6f6", "align": "center" }, "size": { "w": 160, "h": 24 }, "position": { "x": 400, "y": 12 }, "tags": ["hud"], "layer": 100, "behaviors": [] },
    { "id": "hud-hp", "sprite": { "kind": "shape", "shape": "rect", "color": "#a7f070" }, "size": { "w": 160, "h": 12 }, "position": { "x": 626, "y": 16 }, "tags": ["hud"], "layer": 100, "behaviors": [{ "type": "hud-bar", "params": { "valueKey": "hp", "maxKey": "maxHp", "width": 160 } }] }
  ],
  "systems": [
    { "type": "aabb-collision", "params": { "pairs": [["enemy", "player"], ["coin", "player"]] } },
    { "type": "score", "params": { "scoreKey": "kills", "highKey": "best", "storageKey": "reskin.best" } },
    {
      "type": "wave-spawner",
      "params": {
        "interval": "$cfg.spawnInterval",
        "waveSize": "$cfg.waveSize",
        "waveSizeGrowth": "$cfg.waveSizeGrowth",
        "waveDelay": "$cfg.waveDelay",
        "maxWaves": "$cfg.maxWaves",
        "maxAlive": "$cfg.maxAlive",
        "countTag": "enemy",
        "waveKey": "wave",
        "spawnPoints": [{ "x": 60, "y": 60 }, { "x": 740, "y": 60 }, { "x": 60, "y": 540 }, { "x": 740, "y": 540 }, { "x": 400, "y": 40 }],
        "prototype": {
          "id": "mob",
          "sprite": { "kind": "image", "src": "assets/sprites/enemy-chaser.png" },
          "size": { "w": 28, "h": 28 },
          "position": { "x": 0, "y": 0 },
          "tags": ["enemy"],
          "layer": 3,
          "behaviors": [
            { "type": "ai-chase", "params": { "targetTag": "player", "speed": "$cfg.enemySpeed" } },
            { "type": "velocity", "params": {} },
            { "type": "contact-damage", "params": { "targetTag": "player", "damage": "$cfg.enemyDamage", "cooldown": "$cfg.damageCooldown" } },
            { "type": "health-and-death", "params": { "hp": "$cfg.enemyHp", "tallyKey": "kills", "deathEvent": "enemy-died", "deathSound": "explode" } }
          ]
        }
      }
    },
    {
      "type": "win-lose-conditions",
      "params": {
        "conditions": [
          { "key": "kills", "cmp": "gte", "value": "$cfg.killsToWin", "outcome": "win", "winner": "player" },
          { "key": "playerDeaths", "cmp": "gte", "value": "$cfg.deathsToLose", "outcome": "lose", "winner": "none" }
        ]
      }
    },
    { "type": "explosion", "params": { "event": "enemy-died", "count": "$cfg.fxExplosionCount", "speed": "$cfg.fxExplosionSpeed", "ttl": "$cfg.fxExplosionTtl", "gravity": "$cfg.fxExplosionGravity", "size": 5, "colors": ["#ef7d57", "#ffcd75", "#b13e53", "#f4f4f4"] } },
    { "type": "sparkle", "params": { "event": "collect", "count": "$cfg.fxSparkleCount", "speed": "$cfg.fxSparkleSpeed", "ttl": "$cfg.fxSparkleTtl", "gravity": "$cfg.fxSparkleGravity", "size": 3, "colors": ["#ffcd75", "#f4f4f4", "#a7f070"] } }
  ]
}
