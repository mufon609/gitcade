# Next.js build output + generated files (regenerated by `next build`/`dev`).
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Prisma CLI reads DATABASE_URL from this local-only file (mirrors worker/.env).
# Secrets live in the repo-root .env (already gitignored); this is local DB only.
.env
.env.local
