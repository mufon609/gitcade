// GitCade — Phase 4B schema. This is a SUPERSET of the frozen Phase 4A worker
// schema (platform/worker/prisma/schema.prisma): the BuildJob/Build models and
// their enums are copied here VERBATIM so that `prisma db push` from the web app
// is a no-op for those existing tables and only CREATES the new 4B tables.
//
// HARD RULE (per the phase contract): extend ADDITIVELY. We never reshape or
// migrate BuildJob/Build, and we add NO relation field onto them — the Game row
// links to its build by storing the opaque `lastJobId` string (Build.jobId is
// @unique), so the frozen tables stay byte-identical to what 4A created. The web
// app ENQUEUES jobs (inserting BuildJob rows via the frozen contract) and READS
// Build rows; it never builds.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── FROZEN 4A TABLES (verbatim) ─────────────────────────

/// Lifecycle of a queued build job.
enum JobStatus {
  PENDING
  RUNNING
  DONE
}

/// Outcome of an executed build.
enum BuildStatus {
  SUCCESS
  FAILED
}

/// A unit of work for the build worker. Enqueued by the 4A CLI and by the 4B web
/// app (the web app only enqueues + reads — it never builds).
model BuildJob {
  id        String    @id @default(uuid())
  gameSlug  String
  repoUrl   String
  branch    String    @default("main")
  commit    String?
  status    JobStatus @default(PENDING)
  attempts  Int       @default(0)
  claimedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  startedAt DateTime?
  build     Build?

  @@index([status, createdAt])
  @@index([gameSlug, branch, status])
}

/// The result of executing a BuildJob: status, verbatim logs, artifact location.
model Build {
  id           String      @id @default(uuid())
  jobId        String      @unique
  job          BuildJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  gameSlug     String
  repoUrl      String
  branch       String
  commit       String?
  tier         String?
  status       BuildStatus
  stage        String?
  logs         String      @db.Text
  artifactPath String?
  fileCount    Int?
  createdAt    DateTime    @default(now())
  finishedAt   DateTime?

  @@index([gameSlug, branch])
}

// ───────────────────────── NextAuth (GitHub OAuth) ─────────────────────────
// Standard NextAuth Prisma-adapter models. The GitHub access token (granted with
// the explicit `read:user user:email public_repo` scopes) is stored on Account
// so Phase 5 forks / Phase 6 remix commits can act as the user. See src/lib/auth.ts.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────── 4B domain model ─────────────────────────

/// Game lifecycle on the platform. THE VALIDATOR IS THE GATE: a Game only
/// becomes LIVE when its build worker run returns SUCCESS.
enum GameStatus {
  BUILDING // job enqueued, waiting on the worker
  LIVE     // latest build SUCCEEDED — playable
  FAILED   // latest build FAILED — worker logs surfaced verbatim
}

enum GameTier {
  ecosystem
  open
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  /// GitHub login (handle). Used for fork slug naming in Phase 5.
  githubLogin   String?
  isSeed        Boolean  @default(false)
  createdAt     DateTime @default(now())

  accounts      Account[]
  sessions      Session[]
  games         Game[]               @relation("GameOwner")
  playSessions  PlaySession[]
  memberships   CommunityMembership[]
  // Phase 6 marketplace: parts this user published (back-relation, no column).
  parts         Part[]               @relation("PartAuthor")
  // Phase 7 governance relations.
  votes         Vote[]
  bugReports    BugReport[]
  proposals     Proposal[]           @relation("ProposalAuthor")
  notifications Notification[]
}

model Game {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String
  description  String?
  repoUrl      String
  /// The branch the published Game tracks. Phase 5 adds per-branch play; for now
  /// every Game tracks one branch (default "main").
  branch       String     @default("main")
  ownerId      String
  owner        User       @relation("GameOwner", fields: [ownerId], references: [id])
  tier         GameTier
  status       GameStatus @default(BUILDING)
  /// Snapshot of game.json at publish time (manifest shape is frozen in the SDK).
  manifest     Json
  /// Free-text tags for home-grid filtering (Phase 6 marketplace enriches these).
  tags         String[]   @default([])

  /// Opaque pointer to the latest enqueued BuildJob (BuildJob.id). NOT a relation
  /// — deliberately a plain string so the frozen Build/BuildJob tables need no new
  /// back-relation column. The publish service reads the Build via Build.jobId.
  lastJobId    String?

  // ── Phase 5 fork extension point ──
  /// Null for original games; set to the parent Game for forks (Phase 5 wires the
  /// GitHub fork API + the {slug}--{username} naming). The relation exists now so
  /// Phase 5 is purely additive UI/flow.
  parentGameId String?
  parent       Game?      @relation("GameForks", fields: [parentGameId], references: [id])
  forks        Game[]     @relation("GameForks")

  // ── Phase 7 governance extension point ──
  /// GitCade GitHub App installation id on this repo, captured during the
  /// ecosystem publish "Enable community governance" step. Null = app not
  /// installed → Phase 7 proposals are disabled for this game.
  installationId String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  playSessions PlaySession[]
  memberships  CommunityMembership[]
  proposals    Proposal[]
  bugReports   BugReport[]
  // Phase 6 marketplace: the catalog parts this game composes (the "made from"
  // index). Back-relation only — the FK lives on GamePart, so no column is added
  // to the (Phase-4B, never-reshaped) Game table.
  gameParts    GamePart[]

  @@index([tier, status])
  @@index([parentGameId])
  // Phase 8B note: NO ([status, createdAt]) index is added. The home-grid query
  // orders by `status::text` (Prisma casts the enum), which a b-tree on the enum
  // column cannot satisfy; and with no WHERE/LIMIT the planner seq-scans + sorts
  // regardless. Verified by EXPLAIN — see platform/PERFORMANCE.md.
}

/// Recorded each time a game is played. HARD REQUIREMENT of Phase 7's
/// anti-brigading rule (a recorded PlaySession is a voting-eligibility signal).
/// userId is nullable — anonymous play is allowed and still recorded.
model PlaySession {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  branch      String   @default("main")
  startedAt   DateTime @default(now())
  /// Updated by the player heartbeat; total seconds the session has been active.
  durationSec Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@index([gameId, userId])
  @@index([userId, gameId])
}

/// A user joining a game's community. HARD REQUIREMENT of Phase 7 (voting is
/// restricted to members). No other community features in Phase 4B.
model CommunityMembership {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId   String
  game     Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([userId, gameId])
  @@index([gameId])
}

// ───────────────────── Phase 7 — Governance (fills the placeholders) ─────────────────────
// These three tables were created EMPTY in 4B as placeholders; Phase 7 fills them
// with the real governance columns. This is ADDITIVE — the tables hold no rows yet,
// and NO 4A/4B/5/6 table is reshaped. New enums + a Notification table are added.

/// How a proposal becomes code.
///   CONFIG_CHANGE / PART_SWAP — the proposal IS a diff (RemixEdits); on pass +
///     owner approval it auto-commits to main via the GitHub APP installation.
///   FEATURE_REQUEST — free text; on pass it becomes a "help wanted" item closed by
///     a PR linking the proposal. NEVER auto-applies.
enum ProposalType {
  CONFIG_CHANGE
  PART_SWAP
  FEATURE_REQUEST
}

/// The proposal lifecycle. draft → open → (window closes → tally) → passed | failed.
/// A PASSED auto-applicable proposal is then APPLIED (owner approves → app commits)
/// or VETOED (owner blocks with a public reason). A PASSED feature request becomes
/// HELP_WANTED.
enum ProposalStatus {
  DRAFT
  OPEN
  PASSED
  FAILED
  APPLIED
  VETOED
  HELP_WANTED
}

enum VoteChoice {
  YES
  NO
}

enum BugStatus {
  OPEN
  CLOSED
  CONVERTED
}

enum NotificationType {
  PROPOSAL_OPENED
  PROPOSAL_PASSED
  PROPOSAL_FAILED
  PROPOSAL_VETOED
  PROPOSAL_APPLIED
}

model Proposal {
  id        String         @id @default(cuid())
  gameId    String
  game      Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation("ProposalAuthor", fields: [authorId], references: [id])

  type      ProposalType
  status    ProposalStatus @default(DRAFT)
  title     String
  /// Free-text rationale (and, for FEATURE_REQUEST, the acceptance criteria).
  body      String?        @db.Text

  /// For CONFIG_CHANGE / PART_SWAP: the RemixEdits the proposal applies (the diff).
  /// Re-applied against current main at commit time (so it tracks intervening pushes).
  edits     Json?
  /// Snapshots captured at draft time so the proposal page renders a STABLE ConfigDiff
  /// without re-reading the repo, and so the historical diff survives later main drift.
  baseConfig Json?
  headConfig Json?
  /// Human-readable one-liners from applyRemix (the change summary shown on the page).
  changeSummary String[]   @default([])

  // ── voting config (owner-tunable within locked bounds) ──
  thresholdPct Int   @default(70)  // % of votes cast required to pass
  quorum       Int   @default(10)  // minimum total votes
  windowDays   Int   @default(5)   // 1–14, owner-configurable

  openedAt   DateTime?
  closesAt   DateTime?
  decidedAt  DateTime?

  // ── owner veto (the exit door) ──
  vetoedAt   DateTime?
  vetoReason String?   @db.Text

  // ── auto-commit result (app-authored) ──
  appliedCommit String?
  appliedJobId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes     Vote[]
  /// Bug reports converted into this proposal (owner action).
  bugReports BugReport[] @relation("BugToProposal")

  @@index([gameId, status])
  // Phase 8B (perf): voting-eligibility runs `count(WHERE gameId=? AND authorId=?)`
  // on every cast vote. This composite turns it into an Index-Only Scan (vs a
  // bitmap scan of ALL the game's proposals via [gameId,status] + heap recheck).
  // Proven by EXPLAIN — see platform/PERFORMANCE.md.
  @@index([gameId, authorId])
}

model Vote {
  id         String     @id @default(cuid())
  proposalId String
  proposal   Proposal   @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  choice     VoteChoice @default(YES)
  createdAt  DateTime   @default(now())

  @@unique([proposalId, userId])
  @@index([proposalId])
  // Phase 8B (perf): the proposal-tally GROUP BY counts YES/NO per proposal
  // (`WHERE proposalId IN (…) GROUP BY proposalId, choice`). This composite makes
  // it an index-only aggregate (no heap fetch for `choice`).
  @@index([proposalId, choice])
}

model BugReport {
  id         String    @id @default(cuid())
  gameId     String
  game       Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User      @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  title      String
  body       String    @db.Text
  /// The build/commit the bug was observed on (ties a report to a specific state).
  commit     String?
  buildId    String?
  status     BugStatus @default(OPEN)

  /// Set when an owner converts this bug into a proposal.
  proposalId String?
  proposal   Proposal? @relation("BugToProposal", fields: [proposalId], references: [id], onDelete: SetNull)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([gameId, status])
}

/// In-app notifications (v1: no email). Created for community members when a
/// proposal on a game they belong to is opened / passed / vetoed / applied.
model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  message    String
  gameId     String?
  gameSlug   String?
  proposalId String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt])
}

// ───────────────────────── Phase 6 — Marketplace (ADDITIVE) ─────────────────────────
// New tables only. Nothing here references or reshapes a 4A/4B/Phase-5 column;
// `prisma db push` CREATES these and leaves every existing table byte-identical.

/// Where a Part came from. `catalog` rows are ingested from
/// packages/library/CATALOG.json (the library is the frozen source of truth — a
/// queryable mirror, re-ingestable idempotently). `user` rows are owner-published
/// custom parts (vendored into forks at remix time — there is NO private registry).
enum PartSource {
  catalog
  user
}

/// One marketplace part: a row mirroring a CATALOG.json entry (source=catalog) or
/// an owner-published custom behavior/entity (source=user). The DB is a query
/// mirror; the catalog/JSON files remain authoritative for catalog parts.
model Part {
  id             String     @id @default(cuid())
  /// The part identifier (== CATALOG id for catalog parts, e.g. "move-grid-step").
  partId         String
  version        String
  /// behavior | system | entity | asset | ui | fx (the catalog `kind`).
  kind           String
  category       String
  tags           String[]   @default([])
  description    String     @db.Text
  /// MIT (code) | CC-BY-4.0 (assets). MANDATORY at user upload.
  license        String
  source         PartSource @default(catalog)
  /// For catalog parts: the @gitcade/library release the part@version resolves in.
  libraryVersion String?
  /// Part/SDK-builtin type ids this part composes with (from the catalog).
  dependencies   String[]   @default([])
  /// Per-parameter docs (catalog `params`), for the remix slider/form UI.
  paramsDoc      Json?
  /// The ready-to-use instance template (catalog `definition`): drives remix swaps
  /// and the behavior micro-scene preview.
  definition     Json?
  /// A small descriptor the marketplace uses for a live preview:
  ///   { kind: "sprite", src } | { kind: "sfx", key } | { kind: "behavior", type } | ...
  preview        Json?

  // ── user-published provenance (null for catalog parts) ──
  ownerId        String?
  owner          User?      @relation("PartAuthor", fields: [ownerId], references: [id], onDelete: SetNull)
  /// The repo + path the custom part was published FROM (vendoring source).
  sourceRepoUrl  String?
  sourcePath     String?
  /// Verbatim sandbox validation/test log from the upload (readable on failure).
  sandboxLog     String?    @db.Text
  /// The vendored source the remix flow drops into src/vendored-parts/.
  sourceCode     String?    @db.Text

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  usages         GamePart[]

  /// One row per (partId, version, source) — re-ingest UPSERTs in place (idempotent).
  @@unique([partId, version, source])
  @@index([kind, category])
  @@index([source])
}

/// The "made from" index: a game ⇄ catalog part edge with an occurrence count.
/// Populated by parsing a game's scene/entity JSON for `partId@version` provenance
/// refs and resolving them against the catalog. Drives the game-page "Made from"
/// panel and the part-page "used in N games" count.
model GamePart {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  /// The catalog part id + version as referenced in the scene (e.g. "score", "1.0.0").
  partId    String
  version   String
  /// Resolved Part row (nullable: a ref may not resolve in the catalog mirror, e.g.
  /// a not-yet-ingested or removed part — we still record the raw ref).
  partRef   String?
  part      Part?    @relation(fields: [partRef], references: [id], onDelete: SetNull)
  /// How many times this part is referenced across the game's scenes.
  count     Int      @default(1)
  indexedAt DateTime @default(now())

  @@unique([gameId, partId, version])
  @@index([partId])
  @@index([gameId])
}

// ───────────────────────── PHASE 8A — SECURITY (additive) ─────────────────────────

/// Fixed-window rate-limit counter (Phase 8A hardening). One row per
/// (bucket, identity, windowStart): `bucket` is the endpoint class (e.g. "publish"),
/// `identity` is `user:<id>` (authenticated) or `ip:<addr>` (anonymous), and
/// `windowStart` is the floored window boundary. The counter is incremented
/// atomically via INSERT ... ON CONFLICT DO UPDATE (see src/lib/ratelimit.ts), so it
/// is correct under concurrency and survives a process restart / multiple app
/// instances (unlike an in-memory limiter). PURELY ADDITIVE — no existing table is
/// touched; nothing references it. Old windows are harmless and can be GC'd by a
/// periodic `DELETE WHERE "windowStart" < now() - interval`.
model RateLimit {
  id          String   @id @default(cuid())
  /// Endpoint class being limited (e.g. "publish", "fork", "vote").
  bucket      String
  /// `user:<userId>` when authenticated, else `ip:<address>`.
  identity    String
  /// The floored start of the fixed window this counter covers.
  windowStart DateTime
  /// Requests seen in this window for this (bucket, identity).
  count       Int      @default(0)

  @@unique([bucket, identity, windowStart])
  @@index([windowStart])
}
