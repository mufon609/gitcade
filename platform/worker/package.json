{
  "name": "@gitcade/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitCade build worker — consumes the Postgres build queue, builds games in ephemeral sibling containers, uploads servable artifacts to S3/MinIO.",
  "bin": {
    "gitcade-worker": "bin/worker.mjs"
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "start": "tsx src/cli.ts start",
    "build:image": "docker build -t \"${BUILDER_IMAGE:-gitcade-builder:local}\" builder",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@gitcade/sdk": "0.1.0",
    "@prisma/client": "^6.1.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
